services:
  proxy:
    image: nginx:alpine
    ports: ["{{ app_port }}:80"]
    volumes: ["/opt/app/nginx.conf:/etc/nginx/nginx.conf:ro"]
    depends_on: ["frontend", "backend"]
    restart: unless-stopped
  frontend:
    image: "{{ frontend_image }}"
    restart: unless-stopped
    environment:
      NODE_ENV: "production"
  backend:
    image: "{{ backend_image }}"
    restart: unless-stopped
    env_file:
      - /opt/app/backend.env
  
  # --- Monitoring exporters (scraped by Prometheus on Bastion) ---
  node-exporter:
    image: prom/node-exporter:latest
    restart: unless-stopped
    command: ["--path.rootfs=/host"]
    ports:
      - "9100:9100"
    pid: host
    volumes:
      - "/:/host:ro,rslave"

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:latest
    restart: unless-stopped
    ports:
      - "1337:8080"
    volumes:
      - "/:/rootfs:ro"
      - "/var/run:/var/run:ro"
      - "/sys:/sys:ro"
      - "/var/lib/docker/:/var/lib/docker:ro"

  promtail:
    image: grafana/promtail:2.9.3
    restart: unless-stopped
    command: ["-config.file=/etc/promtail/config.yml"]
    environment:
      HOSTNAME: "{{ inventory_hostname }}"
    volumes:
      - "/opt/app/promtail-config.yml:/etc/promtail/config.yml:ro"
      - "/var/log:/var/log:ro"
      - "/var/lib/docker/containers:/var/lib/docker/containers:ro"
      - "/var/run/docker.sock:/var/run/docker.sock:ro"
  
