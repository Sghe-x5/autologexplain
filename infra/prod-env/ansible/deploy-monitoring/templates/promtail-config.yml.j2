server:
  http_listen_port: 1514
  grpc_listen_port: 0

clients:
  - url: "{{ loki_url }}/loki/api/v1/push"
    batchwait: 1s
    backoff_config:
      max_period: 3m
      max_retries: 20
      min_period: 500ms

positions:
  filename: /tmp/positions.yaml

scrape_configs:
  # Docker containers via Docker API for richer labels
  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 5s
    relabel_configs:
      - target_label: job
        replacement: docker
      # Attach node identity for per-host filtering in Grafana
      - target_label: host
        replacement: "{{ inventory_hostname | default(ansible_hostname | default('unknown')) }}"
      - target_label: instance
        replacement: "{{ inventory_hostname | default(ansible_hostname | default('unknown')) }}"
      - source_labels: ['__meta_docker_container_name']
        target_label: container
        regex: '/(.*)'
        replacement: '$1'
      - source_labels: ['__meta_docker_container_image']
        target_label: image
      - source_labels: ['__meta_docker_container_label_com_docker_compose_service']
        target_label: service
      - source_labels: ['__meta_docker_container_label_com_docker_compose_service']
        target_label: service_name
      - source_labels: ['__meta_docker_container_label_com_docker_compose_project']
        target_label: project
      - source_labels: ['__meta_docker_container_label_env']
        target_label: env
      - source_labels: ['__meta_docker_network_ip']
        target_label: ip
      # Tell promtail which file to read for each container
      - source_labels: ['__meta_docker_container_id']
        target_label: __path__
        replacement: /var/lib/docker/containers/$1/$1-json.log
      # Drop promtail's own logs to avoid noise/loops
      - source_labels: ['__meta_docker_container_name']
        regex: '/promtail.*'
        action: drop
    pipeline_stages:
      - docker: {}
      # Optionally drop noisy healthchecks
      - match:
          selector: '{container=~".*(health|healthcheck).*"}'
          action: drop

  # Fallback: system logs
  - job_name: syslog
    static_configs:
      - targets: [localhost]
        labels:
          job: syslog
          host: "{{ inventory_hostname | default(ansible_hostname | default('unknown')) }}"
          instance: "{{ inventory_hostname | default(ansible_hostname | default('unknown')) }}"
          __path__: /var/log/*.log
