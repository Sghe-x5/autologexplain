global:
  scrape_interval: 15s
  evaluation_interval: 30s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node-exporter'
    static_configs:
      - targets:
{% for h in groups['app'] | default([]) %}
          - '{{ hostvars[h].ansible_host | default(h) }}:9100'
{% endfor %}

  - job_name: 'cadvisor'
    static_configs:
      - targets:
{% for h in groups['app'] | default([]) %}
          - '{{ hostvars[h].ansible_host | default(h) }}:1337'
{% endfor %}