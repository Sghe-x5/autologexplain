{
  "title": "Requests & Latency",
  "uid": "req-latency",
  "schemaVersion": 39,
  "version": 1,
  "time": {"from": "now-1h", "to": "now"},
  "templating": {"list": [{"name": "handler", "type": "query", "datasource": "Prometheus", "query": "label_values(http_request_duration_seconds_bucket, handler)", "includeAll": true}]},
  "panels": [
    {"type": "timeseries", "title": "RPS", "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0}, "targets": [{"expr": "sum(rate(http_requests_total[1m]))", "datasource": "Prometheus"}]},
    {"type": "timeseries", "title": "Latency p90/p95/p99", "gridPos": {"h": 10, "w": 24, "x": 0, "y": 8}, "fieldConfig": {"defaults": {"unit": "s"}}, "targets": [
      {"expr": "histogram_quantile(0.90, sum by (le) (rate(http_request_duration_seconds_bucket{handler=~\"$handler\"}[5m])))", "datasource": "Prometheus"},
      {"expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{handler=~\"$handler\"}[5m])))", "datasource": "Prometheus"},
      {"expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{handler=~\"$handler\"}[5m])))", "datasource": "Prometheus"}
    ]},
    {"type": "timeseries", "title": "Response size bytes", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18}, "fieldConfig": {"defaults": {"unit": "bytes"}}, "targets": [{"expr": "sum by (handler) (rate(http_response_size_bytes_sum{handler=~\"$handler\"}[5m])) / sum by (handler) (rate(http_response_size_bytes_count{handler=~\"$handler\"}[5m]))", "datasource": "Prometheus"}]},
    {"type": "timeseries", "title": "Request size bytes", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18}, "fieldConfig": {"defaults": {"unit": "bytes"}}, "targets": [{"expr": "sum by (handler) (rate(http_request_size_bytes_sum{handler=~\"$handler\"}[5m])) / sum by (handler) (rate(http_request_size_bytes_count{handler=~\"$handler\"}[5m]))", "datasource": "Prometheus"}]}
  ]
}
