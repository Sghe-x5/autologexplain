services:
  proxy:
    image: nginx:alpine
    ports: ["{{ app_port }}:80"]
    volumes: ["/opt/app/nginx.conf:/etc/nginx/nginx.conf:ro"]
    depends_on: [frontend, backend]
    restart: unless-stopped
  frontend:
    image: "{{ frontend_image }}"
    restart: unless-stopped
    environment:
      NODE_ENV: "production"
  backend:
    image: "{{ backend_image }}"
    restart: unless-stopped
    env_file:
      - /opt/app/backend.env
  analytics:
    image: "{{ analytics_image }}"
    restart: unless-stopped
    env_file:
      - /opt/app/analytics.env
