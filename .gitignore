# ────────────────────────────────────────────────────────────────
# Системные файлы
# ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ────────────────────────────────────────────────────────────────
# Python
# ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.coverage
.venv/
venv/
env/

# ────────────────────────────────────────────────────────────────
# Node / frontend
# ────────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.env.local
*.tsbuildinfo

# ────────────────────────────────────────────────────────────────
# Secrets & local env (НИКОГДА не коммитить)
# ────────────────────────────────────────────────────────────────
.env
!.env.example
analytics/.env
!analytics/.env.example
backend/.env
!backend/.env.example
# Корпоративные CA-сертификаты (выкачиваются локально под MITM-прокси)
backend/ca-bundle.pem
*.pem

# ────────────────────────────────────────────────────────────────
# Runtime артефакты (генерируются на лету)
# ────────────────────────────────────────────────────────────────
# Celery Beat schedule DB
celerybeat-schedule
celerybeat.pid

# ────────────────────────────────────────────────────────────────
# Локальные Docker overrides (у каждого разработчика свои)
# ────────────────────────────────────────────────────────────────
backend/docker-compose.override.yaml
# Dockerfile.e2e — обход корпоративного MITM при сборке, нужен только локально
backend/Dockerfile.e2e

# ────────────────────────────────────────────────────────────────
# E2E-артефакты: большие CSV генерируются скриптами и не хранятся в репо.
# ────────────────────────────────────────────────────────────────
e2e-artifacts/*.csv
e2e-artifacts/seed_logs.csv
e2e-artifacts/training_logs.csv
e2e-artifacts/seed_labels.csv
e2e-artifacts/training_labels.csv
e2e-artifacts/*.json
e2e-artifacts/*.txt
e2e-artifacts/*.md

# ────────────────────────────────────────────────────────────────
# Личные материалы к защите / презентации
# ────────────────────────────────────────────────────────────────
COURSEWORK_CONTRIBUTION.md
E2E_TEST_REPORT.md
PRESENTATION_BRIEF.md
PRESENTATION_PROMPT.md
PROJECT_EXPLAINED.md
docs/screenshots/

# ────────────────────────────────────────────────────────────────
# IDE
# ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ────────────────────────────────────────────────────────────────
# Terraform (locked state генерируется)
# ────────────────────────────────────────────────────────────────
*.tfstate.backup
.terraform/

# ────────────────────────────────────────────────────────────────
# Logs
# ────────────────────────────────────────────────────────────────
*.log
