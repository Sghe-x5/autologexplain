# --- Virtual Environment ---
# Исключаем папку с виртуальным окружением, чтобы не загружать сотни мегабайт библиотек
.venv/
venv/
env/

# --- Python Cache ---
# Исключаем автоматически генерируемые файлы кеша Python
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Secrets ---
# КРИТИЧЕСКИ ВАЖНО: Никогда не загружайте файл с API-ключами и паролями в репозиторий
.env

# --- Generated Database Files ---
# Исключаем локальные базы данных, которые генерируются при запуске
logs_prod.db
chroma_prod_db/

# --- User-specified Files ---
test.py
freezed.txt

# --- IDE / Editor specific files ---
# Исключаем папки с настройками популярных редакторов кода
.vscode/
.idea/