# --- Images ---
FRONTEND_IMAGE=your-registry/frontend:latest
BACKEND_IMAGE=your-registry/backend:latest
ANALYTICS_IMAGE=your-registry/analytics:latest

# --- AI ---
AI_API_KEY=your-ai-key
AI_MODEL=gpt-3.5-turbo

# --- ClickHouse ---
CLICKHOUSE_HOST=your-clickhouse-host
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-clickhouse-password
CLICKHOUSE_DB=default
CLICKHOUSE_TABLE=logs

# --- Tokens/Secrets ---
TOKEN_SECRET=your-token-secret

# --- Incident Engine ---
INCIDENT_DETECTOR_INTERVAL_MINUTES=2
INCIDENT_DETECTOR_LOOKBACK_MINUTES=360
INCIDENT_DETECTOR_MAX_LOGS=100000
INCIDENT_ANOMALY_THRESHOLD=3.5
INCIDENT_SLO_TARGET=0.995
INCIDENT_CORRELATOR_INTERVAL_MINUTES=1
INCIDENT_CORRELATOR_LOOKBACK_MINUTES=120
INCIDENT_CORRELATOR_MAX_CANDIDATES=500
INCIDENT_CORRELATION_WINDOW_MINUTES=30
INCIDENT_REOPEN_WINDOW_MINUTES=360
INCIDENT_RCA_INTERVAL_MINUTES=3
INCIDENT_RCA_MAX_INCIDENTS=200
INCIDENT_RCA_TRACE_LOOKBACK_MINUTES=180
INCIDENT_JOB_LOCK_TTL_SECONDS=240

# --- Yandex Cloud IAM ---
IAM_TOKEN=
FOLDER_ID=

# --- Valkey/Redis (from Terraform outputs) ---
VALKEY_FQDN=
VALKEY_PASSWORD=
REDIS_DB=0
REDIS_PORT=6379

# --- Optional: Docker registry auth ---
DOCKER_REGISTRY=
DOCKER_REGISTRY_USERNAME=
DOCKER_REGISTRY_PASSWORD=
